{
  "manifest_version": 3,
  "name": "Statut API du Dossier Naturalisation",
  "version": "2.8",
  "description": "Statut API du Dossier Naturalisation",

  "browser_specific_settings": {
    "gecko": {
      "id": "status-naturalisation@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://administration-etrangers-en-france.interieur.gouv.fr/*"
  ],
  "content_scripts": [{
    "matches": ["https://administration-etrangers-en-france.interieur.gouv.fr/*"],
    "js": ["inject.js"],
    "run_at": "document_end"
  }],
  "web_accessible_resources": [{
    "resources": ["content.js", "forge.min.js"],
    "matches": ["https://administration-etrangers-en-france.interieur.gouv.fr/*"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
